# No required environment variables for local development.
# The wallet project ID and backend URL are bundled in source.
#
# To point at a local backend, edit AGENT_URL in src/app/page.tsx:
#   const AGENT_URL = "http://localhost:3001"
#
# Production deployment (Vercel) also needs no env vars — everything
# is configured in source or via the Vercel project settings.
