# Force all text files to LF line endings and UTF-8 in git
* text=auto eol=lf

# Explicitly mark source files as text
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.md text eol=lf
*.env.example text eol=lf

# Binary files — never try to diff or convert
*.png binary
*.jpg binary
*.ico binary
*.woff2 binary